{
	"info": {
		"_postman_id": "empresa-api-collection",
		"name": "POE - Empresas API",
		"description": "Colección de endpoints para gestión de empresas en POE (Path Optimization Engine)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Autenticación",
			"item": [
				{
					"name": "Login - Administrador",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.environment.set(\"access_token\", jsonData.access_token);",
									"    pm.environment.set(\"refresh_token\", jsonData.refresh_token);",
									"    console.log(\"Token guardado: \" + jsonData.access_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "username",
									"value": "admin@poe.com",
									"type": "text"
								},
								{
									"key": "password",
									"value": "admin123",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/usuarios/token",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"usuarios",
								"token"
							]
						},
						"description": "Login como administrador para obtener el access token"
					},
					"response": []
				},
				{
					"name": "Login - Admin Jumbo",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.environment.set(\"access_token_jumbo\", jsonData.access_token);",
									"    pm.environment.set(\"refresh_token_jumbo\", jsonData.refresh_token);",
									"    console.log(\"Token Jumbo guardado: \" + jsonData.access_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "username",
									"value": "mgonzalez@jumbo.cl",
									"type": "text"
								},
								{
									"key": "password",
									"value": "Jumbo2025!",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/usuarios/token",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"usuarios",
								"token"
							]
						},
						"description": "Login como administrador de Jumbo (empresa recién creada)"
					},
					"response": []
				},
				{
					"name": "Login - Admin Lider",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.environment.set(\"access_token_lider\", jsonData.access_token);",
									"    pm.environment.set(\"refresh_token_lider\", jsonData.refresh_token);",
									"    console.log(\"Token Lider guardado: \" + jsonData.access_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "username",
									"value": "cperez@lider.cl",
									"type": "text"
								},
								{
									"key": "password",
									"value": "Lider2025!",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/usuarios/token",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"usuarios",
								"token"
							]
						},
						"description": "Login como administrador de Lider (para probar multi-tenant)"
					},
					"response": []
				}
			]
		},
		{
			"name": "2. Registro de Empresas",
			"item": [
				{
					"name": "Registrar Empresa + Admin",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"empresa\": {\n    \"nombre_empresa\": \"Supermercado Jumbo\",\n    \"rut_empresa\": \"76.123.456-7\",\n    \"direccion\": \"Av. Kennedy 9001, Las Condes\",\n    \"ciudad\": \"Santiago\",\n    \"region\": \"Región Metropolitana\",\n    \"telefono\": \"+56912345678\",\n    \"email\": \"contacto@jumbo.cl\"\n  },\n  \"admin_nombre\": \"María González\",\n  \"admin_correo\": \"mgonzalez@jumbo.cl\",\n  \"admin_contraseña\": \"Jumbo2025!\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/empresas/registro",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"empresas",
								"registro"
							]
						},
						"description": "Registrar una nueva empresa con su usuario administrador (requiere autenticación como admin)"
					},
					"response": []
				},
				{
					"name": "Registrar Empresa Lider",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
