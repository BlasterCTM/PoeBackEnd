						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"telefono\": \"+56912345679\",\n  \"email\": \"nuevo_contacto@jumbo.cl\",\n  \"direccion\": \"Nueva Dirección 123, Santiago\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/empresas/1",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"empresas",
								"1"
							]
						},
						"description": "Actualizar información de una empresa (solo admin de la empresa)"
					},
					"response": []
				}
			]
		},
