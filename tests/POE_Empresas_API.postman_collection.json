								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"empresa\": {\n    \"nombre_empresa\": \"Supermercado Lider\",\n    \"rut_empresa\": \"77.987.654-3\",\n    \"direccion\": \"Av. Libertador Bernardo O'Higgins 3250\",\n    \"ciudad\": \"Santiago\",\n    \"region\": \"Región Metropolitana\",\n    \"telefono\": \"+56987654321\",\n    \"email\": \"contacto@lider.cl\"\n  },\n  \"admin_nombre\": \"Carlos Pérez\",\n  \"admin_correo\": \"cperez@lider.cl\",\n  \"admin_contraseña\": \"Lider2025!\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/empresas/registro",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"empresas",
								"registro"
							]
						},
						"description": "Ejemplo de registro de segunda empresa"
					},
					"response": []
				}
			]
		},
		{
			"name": "3. Consultar Empresas",
			"item": [
				{
					"name": "Listar Todas las Empresas",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/empresas/",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"empresas",
								""
							]
						},
						"description": "Listar todas las empresas (solo administradores)"
					},
					"response": []
				},
				{
					"name": "Listar con Paginación",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/empresas/?skip=0&limit=10&estado=activo",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"empresas",
								""
							],
							"query": [
								{
									"key": "skip",
									"value": "0"
								},
								{
									"key": "limit",
									"value": "10"
								},
								{
									"key": "estado",
									"value": "activo"
								}
							]
						},
						"description": "Listar empresas con paginación y filtro por estado"
					},
					"response": []
				},
				{
					"name": "Ver Mi Empresa",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/empresas/mi-empresa",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"empresas",
								"mi-empresa"
							]
						},
						"description": "Ver información de mi propia empresa (cualquier usuario autenticado)"
					},
					"response": []
				},
				{
					"name": "Ver Empresa por ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/empresas/1",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"empresas",
								"1"
							]
						},
						"description": "Ver empresa específica por ID (solo admin o mismo tenant)"
					},
					"response": []
				}
			]
		},
		{
			"name": "4. Actualizar Empresas",
			"item": [
				{
					"name": "Actualizar Datos de Empresa",
