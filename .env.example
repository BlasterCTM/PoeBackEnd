# ==============================================
# CONFIGURACIÓN DE BASE DE DATOS
# ==============================================

# Usar 'local' para desarrollo local, 'azure' para producción
DATABASE_TARGET=azure

# PostgreSQL Azure (Producción)
AZURE_POSTGRES_HOST=rg-poe-proyecto.postgres.database.azure.com
AZURE_POSTGRES_PORT=5432
AZURE_POSTGRES_USER=admin_blast
AZURE_POSTGRES_PASSWORD=cambiar_en_produccion
AZURE_POSTGRES_DB=POE

# PostgreSQL Local (Desarrollo)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin
POSTGRES_DB=POE

# ==============================================
# SEGURIDAD Y AUTENTICACIÓN
# ==============================================

# Claves secretas (CAMBIAR EN PRODUCCIÓN)
SECRET_KEY=tu_secret_key_super_secreta_cambiar_en_produccion
REFRESH_SECRET_KEY=tu_refresh_secret_key_super_secreta_cambiar_en_produccion

# Expiración de tokens
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=60

# ==============================================
# CONFIGURACIÓN DE SUPERADMIN INICIAL
# ==============================================

# Credenciales del SuperAdmin que se crea automáticamente
# ⚠️ CAMBIAR ESTOS VALORES EN PRODUCCIÓN
SUPERADMIN_EMAIL=superadmin@poe.com
SUPERADMIN_PASSWORD=Admin123!@#
SUPERADMIN_NAME=Super Administrador

# ==============================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ==============================================

# Límites de plan
MAX_TAREAS_PENDIENTES_POR_REPONEDOR=5

# Puerto de la aplicación (para Azure App Service)
WEBSITES_PORT=8000

# ==============================================
# CONFIGURACIÓN DE CORS (Opcional)
# ==============================================

# Separar múltiples orígenes con comas
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://tu-frontend.azurewebsites.net

# ==============================================
# CONFIGURACIÓN DE LOGS (Opcional)
# ==============================================

# Nivel de logs: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO
